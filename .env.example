# API base URL (full URL including protocol and domain)
# Example: https://portfolio-api.downormal.dev
# DO NOT add /api or /api/v1 at the end, as the data sources handle this.
NEXT_PUBLIC_API_BASE_URL=https://portfolio-api.downormal.dev

# Profile ID for accessing user-specific data
NEXT_PUBLIC_PROFILE_ID=9e14987d-8b8d-4c71-9fa9-fd20a8fab81e

# Email Configuration for Contact Form
...

# EmailJS Configuration (Optional - for alternative email service)
# If you want to use EmailJS instead of nodemailer, configure these:
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your-service-id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your-template-id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your-public-key

# Example for testing/development:
# EMAIL_USER=test@example.com
# EMAIL_PASS=test-app-password-12345678
