# Server-side encryption password (change this!)
DATA_ENCRYPTION_PASSWORD=your-server-secret-key-2024

# API key for accessing protected endpoints (change this!)
PORTFOLIO_API_KEY=your-api-key-2024

# Public API key (visible in browser - less secure)
NEXT_PUBLIC_PORTFOLIO_API_KEY=your-api-key-2024

# API base URL (full URL including protocol and domain)
# Example: https://api.example.com or https://portfolio-api.downormal.dev
# DO NOT add /api or /api/v1 at the end, as the data sources handle this automatically.
NEXT_PUBLIC_API_BASE_URL=https://portfolio-api.downormal.dev

# Profile ID for accessing user-specific data
NEXT_PUBLIC_PROFILE_ID=3431d8c5-a4af-478b-8c77-160b4e573123

# EmailJS configuration (for contact form)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_5778a17
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_vubcvmy
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=vraPPHmjghzpuIJ5Y
